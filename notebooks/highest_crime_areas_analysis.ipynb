      "source": [
        "# Research Question: Which areas have the highest crime rates?\n",
        "\n",
        "This notebook analyzes incident counts by area using `LOCATION_TEXT` from the cleaned dataset."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
