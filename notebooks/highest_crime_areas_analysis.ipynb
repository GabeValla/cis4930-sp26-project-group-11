      ],
      "source": [
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from pathlib import Path\n",
        "\n",
        "# Optional for cleaner default style\n",
        "plt.style.use('seaborn-v0_8-whitegrid')\n",
        "\n",
        "# Keep chart outputs scoped to this analysis to reduce merge conflicts\n",
        "FIGURES_DIR = Path('../figures/highest_crime_areas')\n",
        "FIGURES_DIR.mkdir(parents=True, exist_ok=True)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "ebd62c6d",
      "metadata": {},
      "outputs": [],
      "source": [
        "data_path = '../data/processed/tops_crime_data_cleaned.csv'\n",
        "df = pd.read_csv(data_path)\n",
        "\n",
        "print(f'Rows: {len(df):,}')\n",
        "print('Columns:', list(df.columns))\n",
        "df.head()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "34ac0e59",
      "metadata": {},
      "outputs": [],
      "source": [
        "# Use LOCATION_TEXT as area label; fill missing values for grouping\n",
        "df['area'] = df['LOCATION_TEXT'].fillna('Unknown / Not Provided').replace('', 'Unknown / Not Provided')\n",
        "\n",
        "area_counts = (\n",
        "    df.groupby('area')\n",
        "      .size()\n",
        "      .reset_index(name='crime_count')\n",
        "      .sort_values('crime_count', ascending=False)\n",
        ")\n",
        "\n",
        "# Cap counts at 1,000 for clearer plotting while preserving true counts\n",
        "area_counts['crime_count_capped'] = area_counts['crime_count'].clip(upper=1000)\n",
        "\n",
        "area_counts.head(10)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "d03d28ef",
      "metadata": {},
      "source": [
        "The table above shows the areas with the largest number of recorded incidents."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "8bd8995c",
      "metadata": {},
      "outputs": [],
      "source": [
        "# Histogram-style comparison using top 20 areas by incident count (capped at 1,000)\n",
        "top_n = 20\n",
        "top_areas = area_counts.head(top_n).sort_values('crime_count_capped')\n",
        "\n",
        "plt.figure(figsize=(11, 8))\n",
        "plt.barh(top_areas['area'], top_areas['crime_count_capped'], color='steelblue')\n",
        "plt.title(f'Top {top_n} Areas by Crime Count (Capped at 1,000)')\n",
        "plt.xlabel('Number of Incidents (Capped)')\n",
        "plt.ylabel('Area (LOCATION_TEXT)')\n",
        "plt.tight_layout()\n",
        "plt.savefig(FIGURES_DIR / 'highest_crime_areas_top20_capped_1000.png', dpi=200)\n",
        "plt.show()"
      ]
    },
